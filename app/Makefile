	@test -d $(DISTDIR) || mkdir -p $(DISTDIR)
	$(COPY_FILE) --parents $(DIST) $(DISTDIR)/
	$(COPY_FILE) --parents ../../tspi_linux_sdk/buildroot/output/rockchip_rk3566/host/mkspecs/features/data/dummy.cpp $(DISTDIR)/

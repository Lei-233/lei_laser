####### Install

install_target: first FORCE
	@test -d $(INSTALL_ROOT)/opt/LeiLaser || mkdir -p $(INSTALL_ROOT)/opt/LeiLaser
	$(QINSTALL_PROGRAM) $(QMAKE_TARGET) $(INSTALL_ROOT)/opt/LeiLaser/$(QMAKE_TARGET)

uninstall_target: FORCE
	-$(DEL_FILE) $(INSTALL_ROOT)/opt/LeiLaser/$(QMAKE_TARGET)
	-$(DEL_DIR) $(INSTALL_ROOT)/opt/LeiLaser/ 


install: install_target  FORCE

uninstall: uninstall_target  FORCE

